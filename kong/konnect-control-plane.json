{
  "_format_version": "3.0",
  "_transform": true,
  "services": [
    {
      "name": "orders-api",
      "host": "orders-api.platform.local",
      "port": 8080,
      "protocol": "http",
      "tags": [
        "konnect",
        "orders",
        "example"
      ],
      "routes": [
        {
          "name": "orders-public-v1",
          "paths": [
            "/v1/orders"
          ],
          "strip_path": false,
          "plugins": [
            {
              "name": "openid-connect",
              "config": {
                "issuer": "https://auth.dev.example.com",
                "scopes_required": [
                  "orders:read"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}

